# Copy this file to .env and fill in your values
# Never commit the actual .env file to GitHub!

# Your MongoDB connection string (get it from MongoDB Atlas)
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/jobportal

# Secret key for JWT tokens - make this long and random!
JWT_SECRET=your_super_secret_key_make_it_long_and_random_123

# Port the server runs on
PORT=5000
